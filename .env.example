# Provider options:
# mock = offline demo
# openai-compatible = OpenAI / DeepSeek / Qwen / Ollama / LM Studio server
# local-folder = directly load a local GGUF model file from LOCAL_MODEL_DIR
LLM_PROVIDER=mock

# Required when LLM_PROVIDER=openai-compatible.
# Do not commit your real key.
OPENAI_API_KEY=

# Examples:
# OpenAI: gpt-4.1-mini / gpt-4o-mini
# DeepSeek: deepseek-chat
# Qwen: qwen-plus
# Ollama: llama3.1
# LM Studio: local model id shown in LM Studio
MODEL_NAME=gpt-4.1-mini

# Examples:
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# Tongyi Qianwen DashScope compatible mode: https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama: http://localhost:11434/v1
# LM Studio: http://localhost:1234/v1
API_BASE_URL=https://api.openai.com/v1

TEMPERATURE=0.4

# true = no real API call, useful for offline local demos.
USE_MOCK_LLM=true

# Optional app settings.
APP_ENV=development
DATA_DIR=data
REPORT_DIR=exports

# Local model folder mode.
# Put a .gguf model file in this folder, or set this to the full .gguf file path.
LOCAL_MODEL_DIR=models
LOCAL_CONTEXT_WINDOW=4096
LOCAL_MAX_TOKENS=1024
LOCAL_GPU_LAYERS=0
LOCAL_CHAT_FORMAT=
